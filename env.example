# Público no bundle Vite — nunca use service_role aqui
# Project URL (Settings → API). NÃO use a URL que termina em /rest/v1
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Opcional: protege a Edge Function signup-politician (mesmo valor em Supabase → Edge Functions → Secrets)
# VITE_SIGNUP_FUNCTION_SECRET=

# E-mail exibido na tela de conta suspensa (cliente aguardando ativação)
# VITE_PLATFORM_CONTACT_EMAIL=contato@strategos.app
