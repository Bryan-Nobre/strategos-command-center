# Strategos CRM — variáveis de ambiente
# Copie para .env.local (nunca commite secrets)

# --- Supabase (público no bundle — use apenas anon key) ---
# URL do projeto (Settings → API). NÃO inclua /rest/v1
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Edge Function signup (opcional) ---
# Mesmo valor em Supabase → Edge Functions → Secrets → SIGNUP_FUNCTION_SECRET
# VITE_SIGNUP_FUNCTION_SECRET=

# --- Plataforma ---
# E-mail na tela de conta suspensa / cancelada
# VITE_PLATFORM_CONTACT_EMAIL=contato@strategos.app

# --- Deploy Vercel ---
# Configure as mesmas VITE_* no painel Vercel → Settings → Environment Variables
# Build: pnpm build | Output: Nitro/Vercel (ver docs/deploy-vercel.md)

# NUNCA use VITE_ para service_role, private keys ou segredos de backend
